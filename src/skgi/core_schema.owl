<?xml version="1.0"?>
<rdf:RDF xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
         xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
         xmlns:owl="http://www.w3.org/2002/07/owl#"
         xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
         xmlns:skgi="http://skgi.org/ontology/"
         xmlns:dc="http://purl.org/dc/elements/1.1/"
         xml:base="http://skgi.org/ontology/">

    <!-- Ontology Header -->
    <owl:Ontology rdf:about="http://skgi.org/ontology/">
        <rdfs:label>SKGI Core Ontology</rdfs:label>
        <dc:title>Semantic Knowledge Graph Infrastructure Core Schema</dc:title>
        <dc:description>Core ontology for microbiome knowledge graph systems, providing foundational classes and properties for representing microbial data, host associations, and antimicrobial resistance information.</dc:description>
        <dc:creator>Thabet Slimani</dc:creator>
        <dc:date>2026-04-06</dc:date>
        <owl:versionInfo>1.0.0</owl:versionInfo>
        <rdfs:comment>This ontology is designed for the microbiome knowledge graph scoping review and provides a minimal schema for representing microbiome-related knowledge graphs.</rdfs:comment>
    </owl:Ontology>

    <!-- ============================================ -->
    <!-- Core Classes -->
    <!-- ============================================ -->

    <owl:Class rdf:about="http://skgi.org/ontology/MicrobialSample">
        <rdfs:label>Microbial Sample</rdfs:label>
        <rdfs:comment>A biological sample containing microbial communities, typically collected from a host or environment.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/MicrobialTaxon">
        <rdfs:label>Microbial Taxon</rdfs:label>
        <rdfs:comment>A taxonomic classification of a microorganism, aligned with NCBI Taxonomy.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/HostOrganism">
        <rdfs:label>Host Organism</rdfs:label>
        <rdfs:comment>An organism that harbors a microbial community, such as a human, animal, or plant.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/MicrobialFunction">
        <rdfs:label>Microbial Function</rdfs:label>
        <rdfs:comment>A biological function or process performed by microorganisms, typically aligned with Gene Ontology.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/ARG">
        <rdfs:label>Antimicrobial Resistance Gene</rdfs:label>
        <rdfs:comment>A gene that confers resistance to antimicrobial agents, typically aligned with CARD (Comprehensive Antibiotic Resistance Database).</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/ChemicalCompound">
        <rdfs:label>Chemical Compound</rdfs:label>
        <rdfs:comment>A chemical substance of biological relevance, including antimicrobial agents, metabolites, and other compounds, typically aligned with ChEBI.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/Disease">
        <rdfs:label>Disease</rdfs:label>
        <rdfs:comment>A disease or pathological condition associated with microbial communities, typically aligned with MONDO or DOID.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <owl:Class rdf:about="http://skgi.org/ontology/KnowledgeGraph">
        <rdfs:label>Knowledge Graph</rdfs:label>
        <rdfs:comment>A structured knowledge representation integrating microbiome-related data using graph-based approaches.</rdfs:comment>
        <rdfs:subClassOf rdf:resource="http://www.w3.org/2002/07/owl#Thing"/>
    </owl:Class>

    <!-- ============================================ -->
    <!-- Object Properties -->
    <!-- ============================================ -->

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/hasTaxonomicClassification">
        <rdfs:label>has taxonomic classification</rdfs:label>
        <rdfs:comment>Links a microbial sample to its taxonomic classifications.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialSample"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/MicrobialTaxon"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/collectedFromHost">
        <rdfs:label>collected from host</rdfs:label>
        <rdfs:comment>Indicates the host organism from which a microbial sample was collected.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialSample"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/HostOrganism"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/hasFunctionalAnnotation">
        <rdfs:label>has functional annotation</rdfs:label>
        <rdfs:comment>Links a microbial taxon to its functional annotations.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialTaxon"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/MicrobialFunction"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/carriesARG">
        <rdfs:label>carries ARG</rdfs:label>
        <rdfs:comment>Indicates that a microbial taxon carries an antimicrobial resistance gene.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialTaxon"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/ARG"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/confersResistanceTo">
        <rdfs:label>confers resistance to</rdfs:label>
        <rdfs:comment>Links an antimicrobial resistance gene to the chemical compounds it confers resistance against.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/ARG"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/ChemicalCompound"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/associatedWith">
        <rdfs:label>associated with</rdfs:label>
        <rdfs:comment>Links a microbial taxon to a disease it is associated with.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialTaxon"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/Disease"/>
    </owl:ObjectProperty>

    <owl:ObjectProperty rdf:about="http://skgi.org/ontology/containsSample">
        <rdfs:label>contains sample</rdfs:label>
        <rdfs:comment>Links a knowledge graph to the microbial samples it contains.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/KnowledgeGraph"/>
        <rdfs:range rdf:resource="http://skgi.org/ontology/MicrobialSample"/>
    </owl:ObjectProperty>

    <!-- ============================================ -->
    <!-- Datatype Properties -->
    <!-- ============================================ -->

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/sampleId">
        <rdfs:label>sample identifier</rdfs:label>
        <rdfs:comment>A unique identifier for a microbial sample.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialSample"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/collectionDate">
        <rdfs:label>collection date</rdfs:label>
        <rdfs:comment>The date when a microbial sample was collected.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/MicrobialSample"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#date"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/abundance">
        <rdfs:label>relative abundance</rdfs:label>
        <rdfs:comment>The relative abundance of a microbial taxon in a sample.</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/associationScore">
        <rdfs:label>association score</rdfs:label>
        <rdfs:comment>A numerical score indicating the strength of an association (e.g., between microbe and disease).</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/pValue">
        <rdfs:label>p-value</rdfs:label>
        <rdfs:comment>Statistical significance value for an association.</rdfs:comment>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#float"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/graphName">
        <rdfs:label>graph name</rdfs:label>
        <rdfs:comment>A human-readable name for a knowledge graph.</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/KnowledgeGraph"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <owl:DatatypeProperty rdf:about="http://skgi.org/ontology/graphScale">
        <rdfs:label>graph scale</rdfs:label>
        <rdfs:comment>Approximate scale of the knowledge graph (number of nodes).</rdfs:comment>
        <rdfs:domain rdf:resource="http://skgi.org/ontology/KnowledgeGraph"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
    </owl:DatatypeProperty>

    <!-- ============================================ -->
    <!-- Example Instances (for validation) -->
    <!-- ============================================ -->

    <skgi:HostOrganism rdf:about="http://purl.obolibrary.org/obo/NCBITaxon_9606">
        <rdfs:label>Homo sapiens</rdfs:label>
    </skgi:HostOrganism>

    <skgi:MicrobialTaxon rdf:about="http://purl.obolibrary.org/obo/NCBITaxon_562">
        <rdfs:label>Escherichia coli</rdfs:label>
    </skgi:MicrobialTaxon>

    <skgi:MicrobialFunction rdf:about="http://purl.obolibrary.org/obo/GO_0005975">
        <rdfs:label>carbohydrate metabolic process</rdfs:label>
    </skgi:MicrobialFunction>

    <skgi:ChemicalCompound rdf:about="http://purl.obolibrary.org/obo/CHEBI_28001">
        <rdfs:label>vancomycin</rdfs:label>
    </skgi:ChemicalCompound>

    <skgi:Disease rdf:about="http://purl.obolibrary.org/obo/MONDO_0005148">
        <rdfs:label>type 2 diabetes mellitus</rdfs:label>
    </skgi:Disease>

</rdf:RDF>
