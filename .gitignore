#================================================================================
# Git Ignore File for Microbiome KG Scoping Review
#================================================================================

# Python
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
*.egg-info/
.installed.cfg
*.egg

# Virtual environments
venv/
ENV/
env/
.venv

# IDEs
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Testing
.coverage
htmlcov/
.pytest_cache/
.tox/

# Data files (large files should not be tracked)
# Note: Raw data is included in repository for reproducibility
# but can be excluded if too large
data/raw/*.zip
data/raw/*.tar.gz
data/raw/*.tar.bz2

# Output files (generated)
outputs/figures/*.png
outputs/figures/*.jpg
outputs/figures/*.svg
outputs/reports/*.html

# Logs
*.log
logs/

# OS files
Thumbs.db
.DS_Store

# Temporary files
tmp/
temp/
*.tmp

# Documentation builds
docs/_build/
docs/_static/
docs/_templates/

# Environment files (may contain secrets)
.env
.env.local
